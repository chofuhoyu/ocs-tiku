[
    {
        "name": "TikuAdapter题库",
        "url": "http://127.0.0.1:9999/api/search",
        "homepage": "https://github.com/DokiDoki1103/tikuAdapter",
        "method": "post",
        "type": "GM_xmlhttpRequest",
        "contentType": "json",
        "headers": {},
        "data": {
            "question": "${title}",
            "type": "${type}",
            "options": {
                "handler": "return (env)=>env.options?.split('\\n').filter(s => s.trim() && !/^[A-F]\\.?$/.test(s.trim()))"
            }
        },
        "handler": "return (res)=>res.answer.allAnswer.map(i=>([res.question,i.join('#')]))"
    }
]